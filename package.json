{
  "name": "tahta-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Tahta — a pristine, themeable Slidev design system + a visual-grading CLI.",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @tahta/example-edge",
    "grade": "npm run grade -w @tahta/example-edge",
    "assets": "node scripts/gen-assets.mjs",
    "test": "node scripts/check-tokens.mjs && node scripts/check-contrast.mjs",
    "docs": "node scripts/gen-agents.mjs"
  },
  "devDependencies": {
    "sharp": "^0.33.0"
  }
}
