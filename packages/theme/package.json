{
  "name": "slidev-theme-tahta",
  "version": "0.10.6",
  "description": "Tahta — a pristine, themeable Slidev design system. Token-driven style variants, declarative frontmatter layouts, charts.",
  "keywords": [
    "slidev-theme",
    "slidev",
    "presentation",
    "design-system",
    "tahta",
    "slidev-template",
    "keynote",
    "slides",
    "presentation-theme",
    "themeable"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/zcag/tahta",
  "repository": {
    "type": "git",
    "url": "https://github.com/zcag/tahta",
    "directory": "packages/theme"
  },
  "engines": {
    "slidev": ">=0.48.0"
  },
  "bin": {
    "tahta-lint": "./lint.mjs"
  },
  "files": [
    "layouts",
    "components",
    "styles",
    "global-bottom.vue",
    "AGENTS.md",
    "layouts.json",
    "variants.json",
    "tokens.json",
    "lint.mjs"
  ],
  "peerDependencies": {
    "echarts": "^5 || ^6"
  },
  "peerDependenciesMeta": {
    "echarts": {
      "optional": true
    }
  },
  "slidev": {
    "colorSchema": "dark",
    "highlighter": "shiki",
    "fonts": {
      "sans": "Hanken Grotesk",
      "serif": "Fraunces",
      "mono": "JetBrains Mono"
    }
  },
  "dependencies": {
    "@iconify-json/lucide": "^1.2.0",
    "@iconify/vue": "^5.0.0"
  },
  "optionalDependencies": {
    "yaml": "^2.0.0"
  }
}
