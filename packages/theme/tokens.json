{
  "$comment": "The public token contract for slidev-theme-tahta. These semantic CSS custom properties are the design-system foundation: components/layouts read only these, and every variant is a remap of them. Override any of them (e.g. in a deck <style> or a consumer stylesheet) to retheme. Verified against styles/tokens.css by the token-contract test.",
  "groups": {
    "color": {
      "description": "Per-variant palette. The accent ramp (--accent-deep/-soft, --cat-1..5) derives from --accent via OKLCH, so setting one accent reskins charts, tints and shades.",
      "tokens": {
        "--ink": "page background",
        "--ink-2": "raised surface background",
        "--line": "hairline / border color",
        "--fg": "body text",
        "--fg-dim": "secondary text",
        "--accent": "brand accent (override via themeConfig.accent)",
        "--on-accent": "text on an accent fill",
        "--accent-deep": "darker accent (derived)",
        "--accent-soft": "muted accent tint (derived)",
        "--good": "semantic: positive",
        "--warn": "semantic: caution",
        "--bad": "semantic: negative",
        "--info": "semantic: informational",
        "--cat-1": "chart series 1 (derived)",
        "--cat-2": "chart series 2 (derived)",
        "--cat-3": "chart series 3 (derived)",
        "--cat-4": "chart series 4 (derived)",
        "--cat-5": "chart series 5 (derived)",
        "--chart-muted": "muted/baseline chart series"
      }
    },
    "typography": {
      "description": "Font families and a per-role type scale. Use the .fs-* utility classes, never raw sizes.",
      "tokens": {
        "--font-display": "headings / display",
        "--font-body": "body text",
        "--font-serif": "quotes / serif accents",
        "--font-mono": "code, kickers, footers",
        "--w-display": "display weight",
        "--tr-display": "display letter-spacing",
        "--w-strong": "strong/bold weight",
        "--fs-kicker": "kicker label",
        "--fs-lead": "subtitle / lead",
        "--fs-body": "body",
        "--fs-h2": "content title",
        "--fs-cover": "cover title",
        "--fs-section": "section title",
        "--fs-quote": "pull quote",
        "--fs-stat-xl": "hero stat",
        "--fs-stat-lg": "large stat",
        "--fs-stat-md": "stat card",
        "--fs-stat-sm": "small stat",
        "--fs-fact": "fact figure",
        "--fs-bleed-stat": "bleed overlay figure",
        "--fs-step-title": "step title",
        "--opsz-display": "optical size for display (variable fonts)",
        "--opsz-body": "optical size for body"
      }
    },
    "measure": {
      "description": "Max line lengths (ch).",
      "tokens": { "--mw-cover": "", "--mw-title": "", "--mw-prose": "", "--mw-lead": "", "--mw-quote": "" }
    },
    "space": {
      "description": "4pt spacing scale + per-variant density (padding/gap).",
      "tokens": { "--sp-2": "", "--sp-3": "", "--sp-4": "", "--sp-6": "", "--sp-8": "", "--sp-12": "", "--sp-16": "", "--sp-20": "", "--pad-x": "slide horizontal padding", "--pad-y": "slide vertical padding", "--gap": "default gap" }
    },
    "shape": {
      "description": "Radius, borders, and surface treatment.",
      "tokens": { "--radius": "", "--radius-sm": "", "--rule-w": "border width", "--surface-bg": "card background", "--surface-border": "card border", "--surface-shadow": "card elevation", "--code-bg": "code block background" }
    },
    "motion": {
      "description": "Per-variant entrance personality (consumed by <Reveal>).",
      "tokens": { "--motion-dur": "duration", "--motion-ease": "easing", "--reveal-from": "entrance transform", "--stagger": "list stagger step" }
    },
    "atmosphere": {
      "description": "Background and decorative treatment.",
      "tokens": { "--bg-texture": "grain / grid / ruled / none", "--glow": "accent glow", "--card-tick": "show accent tick on cards (1|0)", "--kicker-deco": "kicker decoration (line|bracket|dot|none)" }
    }
  }
}
